# ── SQLite ─────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/ct200.db

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ct200_llm

# ── Gemini ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.5-flash

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
